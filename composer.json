{
    "name": "gamindo/export-engine",
    "description": "Microservizio REST per ingestione statistiche di versione ed export XLSX asincroni configurabili.",
    "keywords": ["lumen", "export", "xlsx", "statistics", "microservice"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^7.3",
        "illuminate/redis": "^8.0",
        "laravel/lumen-framework": "^8.0",
        "league/flysystem": "^1.1",
        "openspout/openspout": "^3.7",
        "predis/predis": "^1.1",
        "ramsey/uuid": "^4.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.14",
        "mockery/mockery": "^1.4.2",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.3.33"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
