APP_NAME="Gamindo Export Engine"
APP_ENV=local
APP_KEY=base64:Y2hhbmdlLW1lLXRoaXMtaXMtYS0zMi1ieXRlLWtleSE=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database -------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=export_engine
DB_USERNAME=export
DB_PASSWORD=secret

# --- Cache / Queue --------------------------------------------------------
# Driver coda: "database" (zero infrastruttura extra) oppure "redis" (consigliato in produzione).
CACHE_DRIVER=redis
QUEUE_CONNECTION=database

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Export ---------------------------------------------------------------
# Disco filesystem dove vengono salvati gli .xlsx generati.
EXPORT_DISK=local
# Soglia massima di righe per un singolo export (protezione anti-abuso).
EXPORT_MAX_ROWS=500000
# Righe restituite dall'endpoint di preview sincrona.
EXPORT_PREVIEW_ROWS=100
# Quante righe processare prima di aggiornare progress/heartbeat sul DB.
EXPORT_PROGRESS_BATCH=2000
# Tentativi automatici del job in caso di errore.
EXPORT_JOB_TRIES=3
# Timeout (secondi) del job di export prima che venga considerato fallito.
EXPORT_JOB_TIMEOUT=3600
